{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valistream/session-report.schema.json",
  "title": "Valistream Session Report",
  "type": "object",
  "required": ["schemaVersion", "session", "stream", "playlists", "findings", "summary"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "session": {
      "type": "object",
      "required": ["id", "inputUrl", "startedAt", "endedAt", "state", "config"],
      "properties": {
        "id": { "type": "string" },
        "inputUrl": { "type": "string", "format": "uri" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "state": { "enum": ["completed", "aborted", "failed"] },
        "interruption": { "type": ["string", "null"] },
        "config": {
          "type": "object",
          "required": ["segmentMode", "bandwidthTolerance", "nonInteractive"],
          "properties": {
            "segmentMode": { "type": "boolean" },
            "bandwidthTolerance": { "type": "number" },
            "timeLimitSeconds": { "type": ["number", "null"] },
            "nonInteractive": { "type": "boolean" },
            "outputDir": { "type": "string" }
          }
        }
      }
    },
    "stream": {
      "type": "object",
      "required": ["kind", "lowLatencyDetected"],
      "properties": {
        "kind": { "enum": ["vod", "event", "live"] },
        "lowLatencyDetected": { "type": "boolean" },
        "encryptionDetected": { "type": "boolean" }
      }
    },
    "playlists": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "url", "selected", "refreshCount"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["master", "media"] },
          "role": { "enum": ["variant", "audio", "subtitles", "iframe", null] },
          "url": { "type": "string", "format": "uri" },
          "selected": { "type": "boolean" },
          "excludedByChoice": { "type": "boolean" },
          "refreshCount": { "type": "integer", "minimum": 0 },
          "cadenceAdherence": { "type": ["number", "null"], "description": "fraction of refreshes on schedule" },
          "stalenessEpisodes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/finding" }
    },
    "segmentAudit": {
      "type": ["object", "null"],
      "properties": {
        "segmentsChecked": { "type": "integer" },
        "segmentsExceedingTolerance": { "type": "integer" },
        "downloadFailures": { "type": "integer" },
        "bytesDownloaded": { "type": "integer" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["countsBySeverity", "countsByCategory", "countsBySource"],
      "properties": {
        "countsBySeverity": {
          "type": "object",
          "properties": {
            "error": { "type": "integer" },
            "warning": { "type": "integer" },
            "info": { "type": "integer" }
          }
        },
        "countsByCategory": { "type": "object", "additionalProperties": { "type": "integer" } },
        "countsBySource": { "type": "object", "additionalProperties": { "type": "integer" } }
      }
    },
    "artifactIndex": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requestId", "url", "bodyPath", "metaPath"],
        "properties": {
          "requestId": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "bodyPath": { "type": "string" },
          "metaPath": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "required": ["id", "ruleId", "source", "severity", "category", "resource", "observedAt", "message"],
      "properties": {
        "id": { "type": "string" },
        "ruleId": { "type": "string" },
        "source": { "enum": ["rfc8216", "apple-authoring", "tool"] },
        "severity": { "enum": ["error", "warning", "info"] },
        "category": { "enum": ["masterPlaylist", "mediaPlaylist", "continuity", "delivery", "segment"] },
        "resource": { "type": "string", "format": "uri" },
        "location": {
          "type": ["object", "null"],
          "properties": {
            "line": { "type": "integer" },
            "tag": { "type": "string" }
          }
        },
        "refreshIndex": { "type": ["integer", "null"] },
        "observedAt": { "type": "string", "format": "date-time" },
        "message": { "type": "string" },
        "context": { "type": "object" }
      }
    }
  }
}
